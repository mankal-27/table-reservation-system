generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Bill {
  id            String   @id @default(uuid())
  reservationId String   @unique // Links back to the Booking Service
  userId        String   // Links back to the User Service
  totalAmount   Float
  status        String   @default("PENDING_PAYMENT") // Will update to PAID once they pay online
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}